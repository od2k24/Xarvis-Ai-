const express = require("express");
const router = express.Router();

const GROQ_API_URL = "https://api.groq.com/openai/v1/chat/completions";
const MODEL = "llama3-8b-8192";

// POST /api/generate
router.post("/", async (req, res, next) => {
  try {
    const { prompt, systemPrompt, temperature = 0.8, maxTokens = 1024 } = req.body;

    if (!prompt || typeof prompt !== "string") {
      return res.status(400).json({ error: "prompt (string) is required" });
    }

    if (!process.env.GROQ_API_KEY) {
      return res.status(500).json({ error: "GROQ_API_KEY is not configured" });
    }

    console.log(`[GENERATE] Prompt: "${prompt.slice(0, 80)}..."`);

    const groqRes = await fetch(GROQ_API_URL, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Authorization: `Bearer ${process.env.GROQ_API_KEY}`,
      },
      body: JSON.stringify({
        model: MODEL,
        messages: [
          {
            role: "system",
            content: systemPrompt || "You are Xarvis AI, a creative and precise content generator.",
          },
          { role: "user", content: prompt },
        ],
        temperature,
        max_tokens: maxTokens,
      }),
    });

    if (!groqRes.ok) {
      const errBody = await groqRes.json().catch(() => ({}));
      const msg = errBody?.error?.message || `Groq error: ${groqRes.status}`;
      console.error(`[GENERATE ERROR] ${msg}`);
      return res.status(groqRes.status).json({ error: msg });
    }

    const data = await groqRes.json();
    const output = data.choices?.[0]?.message?.content || "";

    console.log(`[GENERATE] Output: ${output.length} chars`);

    res.json({
      output,
      model: data.model,
      usage: data.usage,
    });
  } catch (err) {
    next(err);
  }
});

module.exports = router;
