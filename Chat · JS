// /api/chat.js — Xarvis AI V3, Phase 1
// Vercel Edge Runtime — Groq API streaming proxy

export const config = { runtime: 'edge' };

const GROQ_API_URL = 'https://api.groq.com/openai/v1/chat/completions';
const MODEL        = 'llama-3.3-70b-versatile';

// CORS headers — allow Vercel frontend + local dev
const CORS_HEADERS = {
  'Access-Control-Allow-Origin':  '*',
  'Access-Control-Allow-Methods': 'POST, OPTIONS',
  'Access-Control-Allow-Headers': 'Content-Type',
};

export default async function handler(req) {
  // Handle CORS preflight
  if (req.method === 'OPTIONS') {
    return new Response(null, { status: 204, headers: CORS_HEADERS });
  }

  if (req.method !== 'POST') {
    return new Response(
      JSON.stringify({ error: 'Method Not Allowed' }),
      { status: 405, headers: { 'Content-Type': 'application/json', ...CORS_HEADERS } }
    );
  }

  // Validate API key at startup
  const GROQ_API_KEY = process.env.GROQ_API_KEY;
  if (!GROQ_API_KEY) {
    return new Response(
      JSON.stringify({ error: 'GROQ_API_KEY is not configured on this server.' }),
      { status: 500, headers: { 'Content-Type': 'application/json', ...CORS_HEADERS } }
    );
  }

  // Parse request body
  let body;
  try {
    body = await req.json();
  } catch {
    return new Response(
      JSON.stringify({ error: 'Invalid JSON body.' }),
      { status: 400, headers: { 'Content-Type': 'application/json', ...CORS_HEADERS } }
    );
  }

  const { messages, goal } = body;

  // Validate messages array
  if (!Array.isArray(messages) || messages.length === 0) {
    return new Response(
      JSON.stringify({ error: 'messages array is required and must not be empty.' }),
      { status: 400, headers: { 'Content-Type': 'application/json', ...CORS_HEADERS } }
    );
  }

  // ── System Prompt ───────────────────────────────────────
  // Context-aware: includes user's goal when set
  const systemPrompt = buildSystemPrompt(goal);

  // ── Call Groq API ───────────────────────────────────────
  let groqResponse;
  try {
    groqResponse = await fetch(GROQ_API_URL, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${GROQ_API_KEY}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        model:       MODEL,
        messages:    [{ role: 'system', content: systemPrompt }, ...messages],
        stream:      true,
        temperature: 0.72,
        max_tokens:  1024,
        top_p:       1,
      }),
    });
  } catch (err) {
    return new Response(
      JSON.stringify({ error: `Failed to reach Groq API: ${err.message}` }),
      { status: 502, headers: { 'Content-Type': 'application/json', ...CORS_HEADERS } }
    );
  }

  if (!groqResponse.ok) {
    let errorText = '';
    try { errorText = await groqResponse.text(); } catch { errorText = 'Unknown Groq error'; }
    return new Response(
      JSON.stringify({ error: `Groq API error (${groqResponse.status}): ${errorText}` }),
      { status: groqResponse.status, headers: { 'Content-Type': 'application/json', ...CORS_HEADERS } }
    );
  }

  // ── Stream response directly to client ──────────────────
  return new Response(groqResponse.body, {
    status: 200,
    headers: {
      'Content-Type':  'text/event-stream',
      'Cache-Control': 'no-cache, no-transform',
      'X-Accel-Buffering': 'no',
      ...CORS_HEADERS,
    },
  });
}

// ── System Prompt Builder ───────────────────────────────
function buildSystemPrompt(goal) {
  const goalLine = goal
    ? `\n\nThe user's current goal is: "${goal}"\nEvery response should align with helping them achieve this goal. Reference it naturally when relevant.`
    : '\n\nNo goal has been set yet. Your first priority is to help the user define a clear, measurable income goal.';

  return `You are Xarvis — an elite AI co-founder built specifically for creators and solo founders building online income.

Your role is to be PROACTIVE, STRATEGIC, and DIRECT. You are not a general chatbot. You are a co-founder.

Core behaviours:
- Always give ACTIONABLE next steps, not vague advice
- Think in systems: what's the fastest path from where they are to their goal?
- When asked for a plan, give numbered steps with timelines
- When asked for content ideas, give specific, viral-worthy concepts
- Speak like a high-performance operator — no fluff, no hedging
- Format responses clearly: use numbered lists, bold key points, and short paragraphs
- Push the user toward momentum: always end with a next action or question${goalLine}

Rules:
- Never say "I'm just an AI" or similar disclaimers
- Never give generic advice — make it specific to their situation
- If you don't have enough context, ask ONE sharp clarifying question
- Keep responses concise and high-signal — no padding

You are their edge.`;
}
