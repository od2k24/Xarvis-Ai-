'use strict';

const express = require('express');
const router  = express.Router();
const { AGENTS } = require('../agents/agents');

/**
 * POST /api/agent/plan
 * Agent Mode: takes a big goal and creates a full execution plan
 * e.g. "start a content business", "grow to 100k in 90 days"
 */
router.post('/agent/plan', async (req, res) => {
  const groq = req.app.get('groq');
  const { goal, context, memory } = req.body;

  if (!goal?.trim()) return res.status(400).json({ error: 'goal is required' });

  const prompt = `You are Xarvis Agent — a co-founder AI that turns big goals into complete, executable plans.

Creator context: ${context || 'general creator'}
Niche: ${memory?.niche || 'content creation'}
Platform: ${memory?.platform || 'TikTok'}
Goals: ${memory?.goals || goal}

The creator wants to: "${goal}"

Build a COMPLETE AGENT PLAN. Think like a startup co-founder, not a generic advisor.

PHASE 1 — ANALYSIS:
• What is the real goal behind this request?
• What does success look like in 30/60/90 days?
• What are the 3 biggest risks?

PHASE 2 — STRATEGY:
• What's the core approach? (1 paragraph)
• What's the unfair advantage this creator can use?
• What do most people get wrong trying to do this?

PHASE 3 — EXECUTION PLAN:
Week 1: [3 specific actions with expected outcomes]
Week 2: [3 specific actions]
Week 3-4: [3 specific actions]
Month 2: [key milestones]
Month 3: [target state]

PHASE 4 — METRICS:
• Daily metric to track: [specific]
• Weekly milestone: [specific]
• 90-day success benchmark: [specific number]

PHASE 5 — FIRST ACTION:
• Do THIS in the next 24 hours: [one ultra-specific task]`;

  try {
    const completion = await groq.chat.completions.create({
      model:       'llama-3.3-70b-versatile',
      messages: [{ role: 'user', content: prompt }],
      temperature: 0.75,
      max_tokens:  1600,
    });

    const plan = completion.choices[0]?.message?.content || '';
    res.json({ plan, goal, agent: 'executor' });
  } catch (err) {
    console.error('[AGENT/PLAN ERROR]', err.message);
    res.status(500).json({ error: 'Agent planning failed', detail: err.message });
  }
});

/**
 * POST /api/agent/calculate
 * Math and projections — no hallucination, pure logic
 */
router.post('/agent/calculate', async (req, res) => {
  const groq = req.app.get('groq');
  const { question, context } = req.body;

  if (!question?.trim()) return res.status(400).json({ error: 'question is required' });

  const prompt = `You are a precise calculator and business analyst. Show ALL math clearly.

Question: "${question}"
Context: ${context || 'content creator / social media'}

Rules:
- Show every calculation step
- Use realistic industry benchmarks (cite them)
- Give best case / realistic case / conservative case
- End with a single clear recommendation

FORMAT:
📊 ASSUMPTIONS:
[list each assumption with a number]

🧮 CALCULATION:
[step by step math, clearly labeled]

📈 SCENARIOS:
Best case: [result]
Realistic: [result]
Conservative: [result]

✅ RECOMMENDATION:
[What to aim for and why]`;

  try {
    const completion = await groq.chat.completions.create({
      model:       'llama-3.3-70b-versatile',
      messages: [{ role: 'user', content: prompt }],
      temperature: 0.3, // low temp for math accuracy
      max_tokens:  900,
    });

    const result = completion.choices[0]?.message?.content || '';
    res.json({ result, type: 'calculation' });
  } catch (err) {
    console.error('[CALCULATE ERROR]', err.message);
    res.status(500).json({ error: 'Calculation failed', detail: err.message });
  }
});

/**
 * GET /api/agents
 * List available agents
 */
router.get('/agents', (req, res) => {
  res.json({
    agents: Object.entries(AGENTS).map(([key, a]) => ({
      key,
      name:        a.name,
      emoji:       a.emoji,
      description: a.description,
    })),
  });
});

module.exports = router;
