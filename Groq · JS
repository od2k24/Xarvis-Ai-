const express = require("express");
const router  = express.Router();

const GROQ_API_URL = "https://api.groq.com/openai/v1/chat/completions";
const MODEL        = "llama-3.3-70b-versatile";

// ─── POST /api/agent/plan ─────────────────────────────────────────────────────
router.post("/plan", async (req, res) => {
  const { goal, context, memory } = req.body || {};
  const apiKey = process.env.GROQ_API_KEY;

  if (!apiKey) {
    return res.status(500).json({ error: "Missing GROQ_API_KEY on server." });
  }
  if (!goal || typeof goal !== "string" || !goal.trim()) {
    return res.status(400).json({ error: "goal is required." });
  }

  const niche    = memory?.niche    || "content creation";
  const platform = memory?.platform || "YouTube";

  const systemPrompt = `You are Xarvis in Agent Mode — an elite AI co-founder and strategic operator.
You break down big ambitious goals into concrete, week-by-week execution plans that actually work.
You think like a startup founder, content growth hacker, and business builder combined.
Niche: ${niche} | Platform: ${platform}
${context || ""}`.trim();

  const userPrompt = `My goal: "${goal}"

Build me a complete, phased execution roadmap. Be specific — no vague advice.

Structure your response like this:

🎯 GOAL BREAKDOWN
[Reframe the goal into 3 measurable milestones]

📅 PHASE 1 — WEEKS 1–2: Foundation
[5 specific daily/weekly actions to start immediately]

📅 PHASE 2 — WEEKS 3–6: Momentum
[5 specific actions to build traction and systems]

📅 PHASE 3 — WEEKS 7–12: Scale
[5 specific actions to accelerate and monetize]

⚡ QUICK WINS (Do in 24 hours)
[3 things to do TODAY to start moving]

🚧 BIGGEST OBSTACLES & HOW TO BEAT THEM
[Top 3 likely obstacles with specific countermeasures]

💰 MONETIZATION PATH
[Specific revenue streams to build in order, with realistic timelines]

Be direct, tactical, and specific. No filler.`;

  try {
    const groqRes = await fetch(GROQ_API_URL, {
      method:  "POST",
      headers: {
        Authorization:  `Bearer ${apiKey}`,
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        model:       MODEL,
        temperature: 0.7,
        max_tokens:  2000,
        messages: [
          { role: "system", content: systemPrompt },
          { role: "user",   content: userPrompt   },
        ],
      }),
    });

    if (!groqRes.ok) {
      const e = await groqRes.json().catch(() => ({}));
      return res.status(500).json({ error: e?.error?.message || `Groq error ${groqRes.status}` });
    }

    const data = await groqRes.json();
    const plan  = data?.choices?.[0]?.message?.content;

    if (!plan) {
      return res.status(500).json({ error: "Empty response from model" });
    }

    return res.json({ success: true, plan });

  } catch (err) {
    console.error("[agent/plan] error:", err.message);
    return res.status(500).json({ error: err.message || "Internal server error" });
  }
});

module.exports = router;
